<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vet_owner_form" model="ir.ui.view">
            <field name="name">vet.owner.form</field>
            <field name="model">vet.owner</field>
            <field name="arch" type="xml">
                <form string="Dueño">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                        </group>
                        <notebook>
                            <page string="Mascotas">
                                <field name="pet_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="species"/>
                                        <field name="breed"/>
                                        <field name="birth_date"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vet_owner_list" model="ir.ui.view">
            <field name="name">vet.owner.list</field>
            <field name="model">vet.owner</field>
            <field name="arch" type="xml">
                <tree string="Dueños">
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                </tree>
            </field>
        </record>

        <record id="action_vet_owner" model="ir.actions.act_window">
            <field name="name">Dueños</field>
            <field name="res_model">vet.owner</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>