<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vet_treatment_form" model="ir.ui.view">
            <field name="name">vet.treatment.form</field>
            <field name="model">vet.treatment</field>
            <field name="arch" type="xml">
                <form string="Tratamiento">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="appointment_id"/>
                            <field name="pet_id"/>
                            <field name="medicine"/>
                            <field name="dose"/>
                            <field name="duration_days"/>
                            <field name="follow_up_state"/>
                        </group>
                        <group string="Notas">
                            <field name="description"/>
                            <field name="follow_up_notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vet_treatment_list" model="ir.ui.view">
            <field name="name">vet.treatment.list</field>
            <field name="model">vet.treatment</field>
            <field name="arch" type="xml">
                <tree string="Tratamientos">
                    <field name="name"/>
                    <field name="pet_id"/>
                    <field name="medicine"/>
                    <field name="dose"/>
                    <field name="follow_up_state"/>
                    <field name="duration_days"/>
                </tree>
            </field>
        </record>

        <record id="view_vet_treatment_kanban" model="ir.ui.view">
            <field name="name">vet.treatment.kanban</field>
            <field name="model">vet.treatment</field>
            <field name="arch" type="xml">
                <kanban string="Seguimiento de Tratamientos" default_group_by="follow_up_state">
                    <field name="name"/>
                    <field name="pet_id"/>
                    <field name="medicine"/>
                    <field name="follow_up_state"/>
                    <field name="duration_days"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <strong><field name="name"/></strong>
                                    <div>Mascota: <field name="pet_id"/></div>
                                    <div>Medicamento: <field name="medicine"/></div>
                                    <div>Duración: <field name="duration_days"/> días</div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_vet_treatment" model="ir.actions.act_window">
            <field name="name">Tratamientos</field>
            <field name="res_model">vet.treatment</field>
            <field name="view_mode">list,kanban,form</field>
        </record>
    </data>
</odoo>